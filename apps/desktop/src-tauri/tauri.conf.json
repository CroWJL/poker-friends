{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Poker Friends",
  "version": "0.1.0",
  "identifier": "com.pokerfriends.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Poker Friends",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
